              { "selector": "updated_at", "text": "updated_at", "type": "timestamp" }
            ]
          }
        ],
        "fieldConfig": {
          "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "status" },
              "properties": [
                { "id": "custom.cellOptions", "value": { "type": "color-text" } },
                {
                  "id": "mappings",
                  "value": [
                    {
                      "type": "value",
                      "options": {
                        "OK": { "color": "green", "index": 0 },
                        "WARN": { "color": "yellow", "index": 1 },
                        "CRITICAL": { "color": "red", "index": 2 }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "severity" },
              "properties": [
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "green", "value": null },
                      { "color": "yellow", "value": 2 },
                      { "color": "red", "value": 3 }
                    ]
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "cellHeight": "sm",
          "footer": { "show": false }
        }
