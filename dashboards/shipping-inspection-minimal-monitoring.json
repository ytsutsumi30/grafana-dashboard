        "title": "Alert Status",
        "gridPos": { "x": 0, "y": 4, "w": 24, "h": 6 },
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grafanacloud-infinity" },
        "targets": [
          {
            "refId": "A",
            "type": "json",
            "source": "url",
            "url": "__API_BASE_URL__/api/monitoring/grafana-cloud/alert-status",
            "url_options": { "method": "GET" },
            "parser": "backend",
            "root_selector": "",
            "format": "table",
            "columns": [
              { "selector": "area", "text": "area", "type": "string" },
              { "selector": "status", "text": "status", "type": "string" },
              { "selector": "severity", "text": "severity", "type": "number" },
