    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "API / DB Health",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grafanacloud-infinity" },
        "targets": [
          {
            "refId": "A",
            "type": "json",
            "source": "url",
            "url": "__API_BASE_URL__/api/monitoring/grafana-cloud/kpis",
            "url_options": { "method": "GET" },
            "parser": "backend",
            "root_selector": "",
            "format": "table",
            "columns": [
              { "selector": "metric", "text": "metric", "type": "string" },
              { "selector": "value", "text": "value", "type": "number" },
              { "selector": "status", "text": "status", "type": "string" }
            ],
            "filters": [
              { "field": "metric", "operator": "=", "value": "api_db_health" }
            ]
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "/value/" },
          "orientation": "horizontal",
          "textMode": "value",
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center"
        }
      },
